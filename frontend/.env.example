# ── TripPop frontend configuration ──────────────────────────────────────────
# Copy to ".env" (or ".env.local") and adjust. All vars must start with VITE_.

# Mock-first mode. "true" (default) runs the whole flow offline with mock data.
# Set to "false" only after the backend gaps in docs/BACKEND_REVIEW.md are fixed.
VITE_USE_MOCK=true

# Microservice base URLs (used only when VITE_USE_MOCK=false).
VITE_RESERVATION_API=http://localhost:3001
VITE_EVENT_API=http://localhost:3002
VITE_USER_API=http://localhost:3003
VITE_ADMIN_API=http://localhost:3004
