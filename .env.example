# 데이터베이스 설정 (REPLACE_ME 부분을 각자 수정)
DB_NAME=kculture
DB_USER=admin
DB_PASSWORD=REPLACE_ME_STRONG_PASSWORD
DB_HOST=local-db
DB_PORT=3306
DB_CONN_LIMIT=10
# 내 컴퓨터에서 MySQL(3306)이 이미 사용 중이면 충돌을 피하기 위한 외부 포트.
# 컨테이너 내부 통신은 그대로 3306 이라 영향 없음. 3306 이 비어있다면 3306 으로 바꿔도 됨.
DB_HOST_PORT=3307

# 서비스 포트 및 지역 설정
PORT=3004

# [BACKEND_REVIEW #10] CORS: 브라우저 프론트엔드의 origin 을 지정해야 함 (백엔드 포트 아님).
# Vite dev 서버 기본값은 5173. 여러 origin 은 쉼표로 구분.
CORS_ORIGIN=http://localhost:5173

AWS_REGION=ap-northeast-2

# 다국어 자동 번역 (admin-service). 비워두면 자격증명 유무로 자동 결정:
#   - AWS_ACCESS_KEY_ID 있으면 AWS Translate 사용, 없으면 mock 폴백([lang] 접두)
#   - 강제 지정하려면 TRANSLATE_PROVIDER=aws 또는 mock
TRANSLATE_PROVIDER=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
